//
//  Secrets.swift.example
//  Copy this file to `Secrets.swift` (next to it) and fill in the values.
//  `Secrets.swift` is gitignored — never commit your anon key.
//
//  The Supabase anon key is the "publishable" key, designed to be embedded
//  in client apps. It is NOT a secret in the sense that it grants server-side
//  access — RLS policies are what protect your data. Still, treat it as a
//  config value rather than literal source.
//
//  Find your project's anon key:
//    Supabase Dashboard → your project → Settings → API → "anon" public.
//

import Foundation

enum Secrets {
    static let supabaseURL = URL(string: "https://tfmholwqujjfiqqlywyp.supabase.co")!
    static let supabaseAnonKey = "PASTE_YOUR_ANON_KEY_HERE"
}
